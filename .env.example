# Entorno de ejecución (development, staging, production)
NODE_ENV=development

# URL de conexión a base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clave secreta para JWT (¡CAMBIAR EN PRODUCCIÓN!)
JWT_SECRET=ward-dev-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7

# Puerto y CORS
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# Stripe (Pagos)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (Emails)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@wardapp.com.mx

# Google Cloud Storage (Archivos)
GCS_PROJECT_ID=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
GCS_BUCKET_NAME=
