generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppModule {
  inventario
  operaciones
  flotas
  clientes
  finanzas
  admin
}

model Company {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  slug       String   @unique
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users      User[]
  categories MaterialCategory[]
  materials  Material[]
  movements  InventoryMovement[]
  warehouses WarehouseConfig[]
  units      Unit[]


  stripe_customer_id     String?
  stripe_subscription_id String?
  subscription_status    String?
  active_modules         AppModule[] @default([inventario])

  @@map("companies")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  company_id    String   @db.Uuid
  email         String   @unique
  password_hash String
  name          String
  role          String   @default("almacenista")
  active        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  company       Company              @relation(fields: [company_id], references: [id])
  movements     InventoryMovement[]  @relation("CreatedByUser")
  reset_tokens  PasswordResetToken[]
  refresh_tokens RefreshToken[]


  @@map("users")
}

model PasswordResetToken {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model MaterialCategory {
  id          String   @id @default(uuid()) @db.Uuid
  company_id  String   @db.Uuid
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  company   Company    @relation(fields: [company_id], references: [id])
  materials Material[]

  @@unique([company_id, name])
  @@map("material_categories")
}

model Material {
  id              String   @id @default(uuid()) @db.Uuid
  company_id      String   @db.Uuid
  name            String
  sku             String?
  location        String?
  category_id     String   @db.Uuid
  zone_id         String?  @db.Uuid
  unit            String   @default("pieza")
  reference_price Float?
  min_stock       Int      @default(0)
  current_stock   Int      @default(0)
  image_url       String?
  active          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  company   Company             @relation(fields: [company_id], references: [id])
  category  MaterialCategory    @relation(fields: [category_id], references: [id])
  zone      WarehouseZone?      @relation(fields: [zone_id], references: [id], onDelete: SetNull)
  movements InventoryMovement[]

  @@unique([company_id, sku])
  @@map("materials")
}

model WarehouseConfig {
  id         String          @id @default(uuid()) @db.Uuid
  company_id String          @db.Uuid
  width_m    Float           @default(50)
  height_m   Float           @default(30)
  updated_at DateTime        @updatedAt

  company Company         @relation(fields: [company_id], references: [id])
  zones   WarehouseZone[]

  @@map("warehouse_config")
}

model WarehouseZone {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  x_pct       Float
  y_pct       Float
  w_pct       Float
  h_pct       Float
  color       String   @default("#4CAF50")
  config_id   String   @db.Uuid
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  config    WarehouseConfig @relation(fields: [config_id], references: [id], onDelete: Cascade)
  materials Material[]

  @@map("warehouse_zones")
}

enum MovementType {
  entry
  exit
}

model InventoryMovement {
  id             String       @id @default(uuid()) @db.Uuid
  company_id     String       @db.Uuid
  material_id    String       @db.Uuid
  type           MovementType
  quantity       Int
  unit_cost      Float?
  total_cost     Float?
  supplier       String?
  invoice_number String?
  destination    String?
  reason         String?
  notes          String?
  created_by     String       @db.Uuid
  movement_date  DateTime     @default(now())
  created_at     DateTime     @default(now())

  company  Company  @relation(fields: [company_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])
  user     User     @relation("CreatedByUser", fields: [created_by], references: [id])

  @@map("inventory_movements")
}

// Enums para Módulo de Flotas
enum UnitType {
  caja_seca
  refrigerado
  plataforma
  volteo
  pipa
  otro
}

enum UnitStatus {
  disponible
  en_viaje
  mantenimiento
  inactivo
}

// Modelo de Unidades
model Unit {
  id                    String     @id @default(uuid()) @db.Uuid
  company_id            String     @db.Uuid
  plate                 String
  brand                 String?
  model                 String?
  year                  Int?
  type                  UnitType
  axles                 Int
  status                UnitStatus @default(disponible)
  vin                   String?
  insurance_expiry      DateTime?
  fuel_efficiency_km_l  Decimal?   @db.Decimal(10, 2)
  last_maintenance_date DateTime?
  notes                 String?
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@unique([company_id, plate])
  @@unique([company_id, vin])
  @@map("units")
}

// Modelo para Seguridad (Refresh Tokens)
model RefreshToken {
  id           String   @id @default(uuid()) @db.Uuid
  user_id      String   @db.Uuid
  token_hash   String   @unique
  expires_at   DateTime
  revoked      Boolean  @default(false)
  replaced_by  String?  @db.Uuid
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

// Modelos para Rate Limiting y Seguridad
model LoginAttempt {
  id         String    @id @default(uuid()) @db.Uuid
  ip         String
  email      String
  attempts   Int       @default(0)
  lock_until DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@unique([ip, email])
  @@map("login_attempts")
}

model SecurityLog {
  id         String   @id @default(uuid()) @db.Uuid
  event_type String   // e.g., "BRUTE_FORCE_LOCK", "SUSPICIOUS_ACTIVITY"
  ip         String
  email      String?
  details    String?  @db.Text
  created_at DateTime @default(now())

  @@map("security_logs")
}

