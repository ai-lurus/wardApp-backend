generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppModule {
  inventario
  operaciones
  flotas
  clientes
  finanzas
  admin
}

model Company {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users      User[]
  categories MaterialCategory[]
  materials  Material[]
  movements  InventoryMovement[]
  warehouses WarehouseConfig[]

  stripe_customer_id     String?
  stripe_subscription_id String?
  subscription_status    String?
  active_modules         AppModule[] @default([inventario])

  @@map("companies")
}

model User {
  id            String   @id @default(uuid())
  company_id    String
  email         String   @unique
  password_hash String
  name          String
  role          String   @default("almacenista")
  active        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  company       Company              @relation(fields: [company_id], references: [id])
  movements     InventoryMovement[]  @relation("CreatedByUser")
  reset_tokens  PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model MaterialCategory {
  id          String   @id @default(uuid())
  company_id  String
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  company   Company    @relation(fields: [company_id], references: [id])
  materials Material[]

  @@unique([company_id, name])
  @@map("material_categories")
}

model Material {
  id              String   @id @default(uuid())
  company_id      String
  name            String
  sku             String?
  location        String?
  category_id     String
  zone_id         String?
  unit            String   @default("pieza")
  reference_price Float?
  min_stock       Int      @default(0)
  current_stock   Int      @default(0)
  image_url       String?
  active          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  company   Company             @relation(fields: [company_id], references: [id])
  category  MaterialCategory    @relation(fields: [category_id], references: [id])
  zone      WarehouseZone?      @relation(fields: [zone_id], references: [id], onDelete: SetNull)
  movements InventoryMovement[]

  @@unique([company_id, sku])
  @@map("materials")
}

model WarehouseConfig {
  id         String          @id @default(uuid())
  company_id String
  width_m    Float           @default(50)
  height_m   Float           @default(30)
  updated_at DateTime        @updatedAt

  company Company         @relation(fields: [company_id], references: [id])
  zones   WarehouseZone[]

  @@map("warehouse_config")
}

model WarehouseZone {
  id          String   @id @default(uuid())
  name        String
  description String?
  x_pct       Float
  y_pct       Float
  w_pct       Float
  h_pct       Float
  color       String   @default("#4CAF50")
  config_id   String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  config    WarehouseConfig @relation(fields: [config_id], references: [id], onDelete: Cascade)
  materials Material[]

  @@map("warehouse_zones")
}

enum MovementType {
  entry
  exit
}

model InventoryMovement {
  id             String       @id @default(uuid())
  company_id     String
  material_id    String
  type           MovementType
  quantity       Int
  unit_cost      Float?
  total_cost     Float?
  supplier       String?
  invoice_number String?
  destination    String?
  reason         String?
  notes          String?
  created_by     String
  movement_date  DateTime     @default(now())
  created_at     DateTime     @default(now())

  company  Company  @relation(fields: [company_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])
  user     User     @relation("CreatedByUser", fields: [created_by], references: [id])

  @@map("inventory_movements")
}
